# Claude Agent SDK 使用 claude CLI 的认证，无需 API Key
# 确保本机已执行 `claude login` 或设置了 ANTHROPIC_API_KEY

# Claude Agent 配置
# CLAUDE_MODEL=claude-opus-4-6                      # 不填则用 CLI 默认
# CLAUDE_APPEND_SYSTEM_PROMPT=请用中文回复所有问题   # 追加到默认系统提示词后
CLAUDE_CWD=/path/to/your/project        # Agent 工作目录（必填，代码仓库路径）
CLAUDE_ALLOWED_TOOLS=Read,Grep,Glob,Bash,Edit,Write
CLAUDE_GUEST_PERMISSION_MODE=default    # default | acceptEdits | dontAsk | plan

# 额外 MCP 服务器（JSON 对象，key 为名称，value 为配置）
# stdio 示例：{"filesystem": {"command": "npx", "args": ["-y", "@modelcontextprotocol/server-filesystem", "/"]}}
# http 示例：{"my-mcp": {"type": "http", "url": "http://localhost:3001"}}
# sse  示例：{"my-sse": {"type": "sse",  "url": "http://localhost:3002/sse"}}
# MCP_SERVERS={}

# 角色控制：owner 使用 bypassPermissions，其余为 guest
# 逗号分隔，ID 格式与平台一致（飞书 open_id / 企业微信 userid）
OWNER_USER_IDS=ou_xxx,ww_yyy

# 飞书（不配置则禁用）
FEISHU_APP_ID=cli_...
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
# FEISHU_ENCRYPT_KEY=

# 企业微信（不配置则禁用）
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=

# 服务器
PORT=3000
