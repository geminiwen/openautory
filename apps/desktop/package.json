{
  "name": "@openautory/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:server": "TRIPLE=$(rustc -vV | sed -n 's/host: //p') && bun build --compile ../server/src/index.ts --outfile src-tauri/binaries/server-$TRIPLE",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "bun run build:server && tauri build --config '{\"bundle\":{\"externalBin\":[\"binaries/server\"]}}'"
  },
  "dependencies": {
    "@ant-design/icons": "^5",
    "@ant-design/x": "^2",
    "antd": "^5",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/cli": "^2",
    "@tauri-apps/plugin-log": "^2",
    "@vitejs/plugin-react": "^4",
    "typescript": "^5.7",
    "vite": "^6"
  }
}
