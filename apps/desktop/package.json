{
  "name": "@openautory/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:server": "TRIPLE=$(rustc -vV | sed -n 's/host: //p') && bun build --compile ../server/src/index.ts --outfile src-tauri/binaries/server-$TRIPLE",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri:build": "bun run build:server && tauri build --config '{\"bundle\":{\"externalBin\":[\"binaries/server\"]}}'"
  },
  "dependencies": {
    "@ant-design/icons": "^5",
    "@ant-design/x": "^2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "antd": "^5",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/cli": "^2",
    "@tauri-apps/plugin-log": "^2",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@vitejs/plugin-react": "^4",
    "jsdom": "^28.1.0",
    "typescript": "^5.7",
    "vite": "^6",
    "vitest": "^4.0.18"
  }
}
