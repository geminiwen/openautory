{
  "name": "openautory",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/logger",
    "packages/core",
    "packages/adapters/http",
    "apps/server",
    "apps/desktop"
  ],
  "scripts": {
    "kill:3000": "sh -c 'pids=$(lsof -ti tcp:3000); if [ -n \"$pids\" ]; then kill -9 $pids; fi'",
    "dev:clean": "bun run kill:3000 && bun run dev",
    "dev": "bun run --filter @openautory/desktop tauri:dev",
    "build": "bun scripts/build.ts",
    "build:sidecar": "bun scripts/build.ts sidecar",
    "build:desktop": "bun scripts/build.ts desktop"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "typescript": "^5.7.3"
  },
  "dependencies": {
  }
}
